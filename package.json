{
  "name": "oneclaw",
  "version": "0.1.0",
  "private": false,
  "description": "OneClaw monorepo workspace",
  "packageManager": "pnpm@10.26.1",
  "main": "dist/index.js",
  "bin": {
    "oneclaw": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "bun build packages/cli/src/index.ts --target=node --format=esm --outfile dist/index.js",
    "prepublishOnly": "pnpm build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
